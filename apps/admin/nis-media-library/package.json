{
  "name": "@monorepo/nis-media-library",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=24 <26"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "pages:dev": "wrangler pages dev",
    "cloudflare:types": "wrangler types",
    "db:migrate:local": "wrangler d1 migrations apply nis-media-library-preview --local",
    "db:migrate:preview": "wrangler d1 migrations apply nis-media-library-preview --remote",
    "db:migrate:production": "wrangler d1 migrations apply nis-media-library-production --remote --env production",
    "db:seed": "node scripts/seed-bootstrap-admin.mjs",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "type-check": "tsc --noEmit && tsc -p tsconfig.functions.json",
    "clean": "rm -rf dist .turbo node_modules/.tmp",
    "format": "prettier --write src functions"
  },
  "dependencies": {
    "jose": "^6.1.3",
    "lucide-react": "^0.575.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@cloudflare/workers-types": "^5.20260723.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^29.0.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.1.5",
    "wrangler": "^4.112.0"
  }
}
