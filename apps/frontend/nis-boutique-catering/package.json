{
  "name": "@monorepo/nis-boutique-catering",
  "private": true,
  "version": "0.1.2",
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=24 <26"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "content:check": "node scripts/check-content.mjs",
    "content:sync": "node scripts/sync-content.mjs",
    "content:sync:cloudflare": "tsx scripts/sync-cloudflare-content.ts",
    "migration:transform": "tsx scripts/migrate-legacy-backup.ts",
    "lint": "eslint .",
    "media:check": "node scripts/check-media.mjs",
    "media:optimize": "node scripts/optimize-media.mjs",
    "perf:lighthouse": "node scripts/run-lighthouse.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate": "pnpm type-check && pnpm lint && pnpm content:check && pnpm media:check && pnpm test && pnpm build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist build .turbo",
    "format": "prettier --write src"
  },
  "dependencies": {
    "@monorepo/content-schema": "workspace:*",
    "@monorepo/site-preview": "workspace:*",
    "lucide-react": "^0.575.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^29.0.2",
    "tsx": "^4.23.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.1.5"
  }
}
