{
  "name": "nis-boutique-catering-monorepo",
  "version": "1.0.1",
  "description": "Monorepo for the nis Boutique Catering website",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=24 <26",
    "pnpm": "9.15.9"
  },
  "scripts": {
    "doctor:runtime": "node scripts/check-runtime.mjs",
    "architecture:boundaries": "node scripts/check-architecture-boundaries.mjs",
    "migration:plan:audit": "node scripts/audit-legacy-migration-plan.mjs",
    "tracker:check": "node scripts/check-redesign-tracker.mjs",
    "design:tokens:check": "node scripts/check-design-tokens.mjs",
    "motion:check": "node scripts/check-motion-system.mjs",
    "security:headers": "node scripts/check-response-headers.mjs",
    "artifacts:list": "node scripts/local-artifacts.mjs list",
    "artifacts:clean": "node scripts/local-artifacts.mjs clean",
    "parity:local": "node scripts/run-local-parity.mjs validate",
    "parity:local:deploy": "node scripts/run-local-parity.mjs deploy",
    "dev": "turbo run dev --filter @monorepo/nis-boutique-catering",
    "dev:all": "turbo run dev",
    "admin:dev": "turbo run dev --filter @monorepo/nis-content-studio",
    "admin:pages:dev": "pnpm --filter @monorepo/nis-content-studio pages:dev",
    "cloudflare:types": "pnpm --filter @monorepo/nis-content-studio cloudflare:types",
    "admin:build": "turbo run build --filter @monorepo/nis-content-studio",
    "build": "turbo run build",
    "cloudflare:build:admin": "pnpm --filter @monorepo/nis-content-studio build",
    "cloudflare:build:site": "pnpm content:sync && pnpm --filter @monorepo/nis-boutique-catering build",
    "lint": "turbo run lint",
    "content:check": "pnpm --filter @monorepo/nis-boutique-catering content:check",
    "content:seed": "pnpm --filter @monorepo/nis-boutique-catering content:seed",
    "content:sync": "pnpm --filter @monorepo/nis-boutique-catering content:sync",
    "media:check": "pnpm --filter @monorepo/nis-boutique-catering media:check",
    "media:optimize": "pnpm --filter @monorepo/nis-boutique-catering media:optimize",
    "perf:lighthouse": "pnpm --filter @monorepo/nis-boutique-catering perf:lighthouse",
    "format": "turbo run format",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "type-check": "turbo run type-check",
    "validate": "pnpm tracker:check && pnpm architecture:boundaries && pnpm design:tokens:check && pnpm motion:check && pnpm security:headers && turbo run content:check media:check lint test type-check && turbo run build"
  },
  "volta": {
    "node": "24.11.0",
    "pnpm": "9.15.9"
  },
  "devDependencies": {
    "turbo": "^2.0.0"
  },
  "workspaces": [
    "packages/*",
    "apps/frontend/nis-boutique-catering",
    "apps/admin/nis-content-studio"
  ]
}
