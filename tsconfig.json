{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@monorepo/shared-types": ["packages/shared-types/src"],
      "@monorepo/shared-types/*": ["packages/shared-types/src/*"],
      "@monorepo/shared-utils": ["packages/shared-utils/src"],
      "@monorepo/shared-utils/*": ["packages/shared-utils/src/*"],
      "@monorepo/emergency-protocol-diagram": ["apps/frontend/emergency-protocol-diagram/src"],
      "@monorepo/lev-chedva-admin": ["apps/frontend/lev-chedva-admin/src"],
      "@monorepo/online-converter": ["apps/frontend/online-converter/src"],
      "@monorepo/test-yourself": ["apps/frontend/test-yourself/src"],
      "@monorepo/uh-shoham-client": ["apps/frontend/uh-shoham-client/src"],
      "@monorepo/web-portfolio": ["apps/frontend/web-portfolio/src"],
      "@monorepo/hebrew-schedule": ["apps/frontend/hebrew-schedule/src"],
      "@monorepo/lev-chedva-website": ["apps/frontend/lev-chedva-website/src"],
      "@monorepo/emergency-protocol-server": ["apps/backend/emergency-protocol-server/src"],
      "@monorepo/lev-hedva-api": ["apps/backend/4/src"],
      "@monorepo/test-yourself-api": ["apps/backend/test-yourself-api/src"],
      "@monorepo/uh-shoham-server": ["apps/backend/uh-shoham-server/src"]
    }
  },
  "include": ["apps/**/*.ts", "apps/**/*.tsx", "packages/**/*.ts", "packages/**/*.tsx"],
  "exclude": ["node_modules", "dist", "build", ".turbo"]
}
